{
  "name": "portfolio-tracker",
  "private": true,
  "version": "1.5.0",
  "description": "Canadian Bank Investment Portfolio Tracker",
  "author": "Don Sinha",
  "repository": {
    "type": "git",
    "url": "https://github.com/dwaipayansinha/PortfolioTracker.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.8.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.479.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.portfolio.tracker",
    "productName": "Portfolio Tracker",
    "copyright": "Copyright © 2026 Don Sinha",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/portfolio_api.exe",
        "to": "portfolio_api.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/electron-vite.svg",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Portfolio Tracker",
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dwaipayansinha",
        "repo": "PortfolioTracker"
      }
    ]
  }
}
