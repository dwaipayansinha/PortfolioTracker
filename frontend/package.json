{
  "name": "portfolio-tracker",
  "private": true,
  "version": "1.0.0",
  "description": "Canadian Bank Investment Portfolio Tracker",
  "author": "Don Sinha",
  "repository": {
    "type": "git",
    "url": "https://github.com/dwaipayansinha/PortfolioTracker.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "package": "electron-forge package",
    "start": "electron-forge start",
    "make": "electron-forge make"
  },
  "dependencies": {
    "axios": "^1.8.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.479.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.portfolio.tracker",
    "productName": "Portfolio Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/portfolio_api.exe",
        "to": "backend/portfolio_api.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Portfolio Tracker"
    }
  }
}
